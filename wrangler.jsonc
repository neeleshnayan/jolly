{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "drizzle",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "DEPLOY_TARGET": "cloudflare",
    "LLM_PROVIDER": "cloudflare",
    "CF_ACCOUNT_ID": "6ccc25465024c8f2009b4474357c298e",
    "CF_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "CF_LIVE_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "RESUME_VISION_PROVIDER": "cloudflare",
    "CF_VISION_MODEL": "@cf/meta/llama-3.2-11b-vision-instruct"
  },
  "hyperdrive": [
    { "binding": "HYPERDRIVE", "id": "b860d77a3d36481393cbd3e35a5d911a" }
  ],
  "observability": { "enabled": true }
}
