{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "drizzle",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-12-30",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "DEPLOY_TARGET": "cloudflare",
    "LLM_PROVIDER": "openrouter",
    "CF_ACCOUNT_ID": "6ccc25465024c8f2009b4474357c298e",
    "CF_MODEL": "@cf/meta/llama-3.1-8b-instruct-fast",
    "CF_LIVE_MODEL": "@cf/meta/llama-3.1-8b-instruct-fast",
    "RESUME_VISION_PROVIDER": "openrouter",
    "CF_VISION_MODEL": "@cf/meta/llama-3.2-11b-vision-instruct",
    "RANK_FN_URL": "https://qlrjkiqznvvrnxbvbstc.supabase.co/functions/v1/rank",
    "SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InFscmpraXF6bnZ2cm54YnZic3RjIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMxMDUzMzQsImV4cCI6MjA5ODY4MTMzNH0.H8VuLwo-xhqPJezH96V4MV4ZTKqQgDrXIIQDg_QYk6A",
    "DEEPGRAM_ALLOW_RAW": "1",
    "LLM_PROVIDER_MENTOR": "openrouter",
    "OPENROUTER_MODEL": "google/gemma-4-31b-it:free",
    "LLM_FALLBACK_LOCAL": "false",
    "OPENROUTER_APP_URL": "https://drizzle.drizzlenetwork.workers.dev",
    "VOICE_PROVIDER": "openrouter",
    "OPENROUTER_STT_MODEL": "openai/whisper-large-v3-turbo",
    "OPENROUTER_TTS_MODEL": "hexgrad/kokoro-82m",
    "OPENROUTER_TTS_VOICE": "am_michael"
  },
  "hyperdrive": [
    { "binding": "HYPERDRIVE", "id": "b860d77a3d36481393cbd3e35a5d911a" }
  ],
  // (Smart Placement removed: the Worker no longer does heavy DB work — it fetches
  // the Supabase Edge ranker, which lives next to the DB. Run near the visitor.)
  "observability": { "enabled": true }
}
