# Supabase → Project Settings → Database → Connection string
# Pooler (port 6543) for the app runtime:
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# Direct (port 5432) for migrations / drizzle-kit:
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="..."
SUPABASE_SERVICE_ROLE_KEY="..."   # server-only, never expose to the client

# ---- LLM provider ----
# "ollama" (free, local) or "anthropic" (quality). Defaults to anthropic.
LLM_PROVIDER="ollama"

# Ollama (local dev). gemma3:27b honors JSON `format`; qwen3:8b is the fast
# "live" model for voice turns. Pull them first: `ollama pull gemma3:27b`
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma3:27b"
OLLAMA_LIVE_MODEL="qwen3:8b"

# Anthropic (optional quality path)
ANTHROPIC_API_KEY="..."
ANTHROPIC_MODEL="claude-sonnet-5"
ANTHROPIC_LIVE_MODEL="claude-sonnet-5"

# OpenRouter (one key, many hosted models). Wired but inert until set. Route a
# single task to a hosted model while keeping the rest local + free, e.g. spend
# on the mentor only:  LLM_PROVIDER_MENTOR=openrouter
OPENROUTER_API_KEY="..."
OPENROUTER_MODEL="anthropic/claude-sonnet-4.5"
# LLM_PROVIDER_MENTOR="openrouter"

# ---- Voice (Voicebox — local STT + TTS at 127.0.0.1:17493) ----
VOICEBOX_BASE_URL="http://127.0.0.1:17493"
VOICEBOX_TTS_ENGINE="kokoro"
VOICEBOX_TTS_PROFILE_ID="..."       # a voice profile id from the Voicebox app
VOICEBOX_STT_MODEL="medium"         # whisper size

# ---- Auth ----
SESSION_SECRET="..."                # random 32+ bytes; signs the session cookie
LINKEDIN_CLIENT_ID="..."            # LinkedIn dev app → Auth
LINKEDIN_CLIENT_SECRET="..."
LINKEDIN_REDIRECT_URI="http://localhost:3000/api/auth/linkedin/callback"